# ──────────────────────────────────────────────────────────────────────────
# BOANERGES — Environment Variables
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# `NEXT_PUBLIC_*` vars are exposed to the browser — keep secrets out of them.
# ──────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000        # canonical URL, used for SEO/OG + webhook/callback URLs

# ── Supabase (Postgres + Auth + Storage) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key          # public, RLS-protected
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key      # SERVER ONLY — bypasses RLS, never expose
SUPABASE_STORAGE_BUCKET=artworks                              # storage bucket for artwork images

# ── Stripe (card, USD — international) ──────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx                                 # SERVER ONLY
STRIPE_WEBHOOK_SECRET=whsec_xxx                               # verifies webhook signatures

# ── Blockonomics (Bitcoin — international) ──────────────────────────────────
BLOCKONOMICS_API_KEY=your_blockonomics_api_key                # SERVER ONLY
BLOCKONOMICS_CALLBACK_SECRET=random_long_secret               # appended to callback URL to authenticate it
BLOCKONOMICS_CONFIRMATIONS=2                                  # confirmations required to mark paid

# ── Paystack (card/bank, NGN — Nigeria) ────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx                               # SERVER ONLY
PAYSTACK_WEBHOOK_SECRET=                                      # optional; Paystack signs with secret key by default

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx                                         # SERVER ONLY
EMAIL_FROM="BOANERGES <orders@yourdomain.com>"
EMAIL_ADMIN_TO=admin@yourdomain.com                          # admin order notifications

# ── Analytics (privacy-aware; pick one or none) ────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=                                 # e.g. yourdomain.com (cookieless)
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# ── Admin bootstrap ────────────────────────────────────────────────────────
ADMIN_ALLOWLIST_EMAILS=admin@yourdomain.com                  # comma-separated; gate admin access

# ── Ambient sound (optional) ───────────────────────────────────────────────
NEXT_PUBLIC_AMBIENT_AUDIO_URL=                               # URL of a looping ambient track; toggle hidden if unset
